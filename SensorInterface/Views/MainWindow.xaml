<Window x:Class="SensorInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SensorInterface"
        mc:Ignorable="d"
        Title="SIMI - Sistema Integrado de Monitoramento Industrial" Height="450" Width="800">
    <StackPanel>
        <Button Content="Atualizar Dados do SQLite"
                Margin="10"
                Padding="5"
                Command="{Binding CarregarSensoresCommand}"/>

        <ListBox Margin="10"
                 Height="350"
                 ItemsSource="{Binding ListaSensores}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Timestamp, StringFormat='[{0:HH:mm:ss}]'}" 
                                       FontWeight="Bold" Margin="0,0,10,0" Foreground="Gray"/>

                            <TextBlock Text="Temperatura: "/>
                            <TextBlock Text="{Binding Temperatura}" FontWeight="Bold"/>
                            <TextBlock Text="ºC" Margin="0,0,20,0"/>

                            <TextBlock Text="Pressão: "/>
                            <TextBlock Text="{Binding Pressao}" FontWeight="Bold" Foreground="DodgerBlue"/>
                            <TextBlock Text=" PSI"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Window>